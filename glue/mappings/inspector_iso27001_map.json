{
  "_metadata": {
    "description": "Maps AWS Inspector finding types to ISO 27001:2022 Annex A controls",
    "version": "1.0.0",
    "framework": "ISO 27001:2022",
    "source": "AWS Inspector v2 vulnerability and network reachability findings",
    "last_updated": "2026-03-11"
  },

  "finding_type_defaults": {
    "PACKAGE_VULNERABILITY": ["A.8.8"],
    "NETWORK_REACHABILITY": ["A.8.20"],
    "CODE_VULNERABILITY": ["A.8.8", "A.8.28"],
    "RUNTIME_BEHAVIOR_ANALYSIS": ["A.8.16"]
  },

  "resource_type_defaults": {
    "AWS_EC2_INSTANCE": ["A.8.8", "A.8.20"],
    "AWS_ECR_CONTAINER_IMAGE": ["A.8.8", "A.8.25"],
    "AWS_ECR_REPOSITORY": ["A.8.8", "A.8.25"],
    "AWS_LAMBDA_FUNCTION": ["A.8.8", "A.8.9"]
  },

  "network_reachability_overrides": {
    "OPEN_PORT": ["A.8.20", "A.8.21"],
    "RECOGNIZED_PORT_WITH_LISTENER": ["A.8.20", "A.8.21"],
    "UNRECOGNIZED_PORT_WITH_LISTENER": ["A.8.20", "A.8.21"],
    "NETWORK_EXPOSURE": ["A.8.20"]
  },

  "cve_severity_overrides": {
    "CVE-2021-44228": {
      "controls": ["A.8.8", "A.8.9"],
      "note": "Log4Shell - critical remote code execution"
    },
    "CVE-2024-3094": {
      "controls": ["A.8.8", "A.8.9"],
      "note": "XZ Utils backdoor - supply chain compromise"
    }
  },

  "annex_a_controls": {
    "A.5.15": "Access Control",
    "A.8.7":  "Protection Against Malware",
    "A.8.8":  "Management of Technical Vulnerabilities",
    "A.8.9":  "Configuration Management",
    "A.8.16": "Monitoring Activities",
    "A.8.20": "Network Security",
    "A.8.21": "Security of Network Services",
    "A.8.25": "Secure Development Life Cycle",
    "A.8.28": "Secure Coding"
  }
}
